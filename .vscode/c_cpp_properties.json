            "intelliSenseMode": "gcc-x64"
        },
        {
            "name": "HMI",
            "includePath": [
                "${workspaceFolder}/github_headers/hmi",     // 指向GitHub上的头文件
                "${workspaceFolder}/hmi_project/include"
            ],
            "defines": [
                "__HMI__"
            ],
            "compilerPath": "",
            "cStandard": "c11",
            "intelliSenseMode": "gcc-x64"
        }
    ],
    "version": 4
