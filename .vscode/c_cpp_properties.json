
{
    "configurations": [
        {
            "name": "ASRPRO-Editor",
            "includePath": [
                "${workspaceFolder}/.vscode/ASR/myLib" // 指向GitHub上的头文件
                //"${workspaceFolder}/asrpro_project/include"  // 如果还想看ASRPRO本地头文件
            ],
            "defines": [
                "__ASRPRO__",
             //   "_DEBUG"
            ],
            "compilerPath": "",
            "cStandard": "c11",
            "cppStandard": "c++17",
            "intelliSenseMode": "gcc-x64",
            "configurationProvider": "ms-vscode.cpptools",
            "browse": {
                "path": [
                    "${workspaceFolder}/.vscode/ASR/src",
                    "${workspaceFolder}/.vscode/ASR/myLib"//,
                //    "${workspaceFolder}/asrpro_project/include"
                ],
                "limitSymbolsToIncludedHeaders": false
            }
        },
        {
            "name": "HMI-Editor",
              "includePath": [
                "${workspaceFolder}/.vscode/HMI/include"     // 指向GitHub上的头文件
                //"${workspaceFolder}/HMI/include"
            ],
            "defines": [
                "__HMI__"
            ],
            "compilerPath": "",
            "cStandard": "c11",
            "cppStandard": "c++17",
            "intelliSenseMode": "gcc-x64",
            "configurationProvider": "ms-vscode.cpptools",
            "browse": {
                "path": [
                    "${workspaceFolder}/.vscode/HMI/src",
                    "${workspaceFolder}/.vscode/HMI/Lib",
                    "${workspaceFolder}/.vscode/HMI/include"
                ],
                "limitSymbolsToIncludedHeaders": false
            }
        }
    ],
    "version": 4
}

